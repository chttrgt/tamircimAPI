# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=TamircimDB
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# JWT - En az 32 karakter, güvenli rastgele string kullanın
JWT_SECRET_KEY=your_very_long_and_secure_jwt_secret_key_at_least_32_chars

# CORS - Frontend URL'leri (noktalı virgülle ayırın)
CORS_ORIGINS=http://localhost:5173;http://localhost:3000

# İzin verilen hostlar (opsiyonel)
ALLOWED_HOSTS=*

# Uygulama DB rolü şifresi (tamircim_app — NOSUPERUSER). Uygulama bu rolle bağlanır,
# böylece Row-Level Security etkin kalır (postgres superuser ile bağlanılırsa RLS
# bypass edilir, tenant izolasyonu çöker). Bağlantı dizesinde sorun çıkmaması için
# ALFANÜMERİK seçin (özellikle ; @ : karakterlerinden kaçının).
APP_DB_PASSWORD=your_app_role_password_alphanumeric

# E-posta doğrulama (self-servis kayıt). Doğrulama linki APP_PUBLIC_URL üzerine kurulur
# (ör. https://api.example.com → .../api/auth/verify-email?token=...).
APP_PUBLIC_URL=https://api.example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=Tamircim

# Cloudflare Turnstile bot koruması (kayıt endpoint'i). Üretimde gerçek secret gir.
# Local/test için Cloudflare test secret'ı: 1x0000000000000000000000000000000AA (her zaman geçer)
TURNSTILE_SECRET=your_turnstile_secret_key

# Sentry hata izleme (opsiyonel). Boş bırakılırsa Sentry devre dışı kalır.
SENTRY_DSN=
