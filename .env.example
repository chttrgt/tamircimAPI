# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=TamircimDB
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# JWT - En az 32 karakter, güvenli rastgele string kullanın
JWT_SECRET_KEY=your_very_long_and_secure_jwt_secret_key_at_least_32_chars

# CORS - Frontend URL'leri (noktalı virgülle ayırın)
CORS_ORIGINS=http://localhost:5173;http://localhost:3000

# İzin verilen hostlar (opsiyonel)
ALLOWED_HOSTS=*
